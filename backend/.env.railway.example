NODE_ENV=production
PORT=8000

# Core app
DATABASE_URL=postgresql://postgres:password@host:5432/pit_portal
JWT_SECRET=replace-with-a-strong-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=14

# Public URLs
PUBLIC_WEB_URL=https://querylinker-portal.netlify.app
PUBLIC_API_URL=https://api.your-domain.com/api/v1
FRONTEND_URL=https://querylinker-portal.netlify.app
CORS_ALLOWED_ORIGINS=https://querylinker-portal.netlify.app

# Split-domain cookie policy
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
COOKIE_DOMAIN=

# AI service
AI_CLASSIFIER_URL=https://ai-your-domain.up.railway.app/predict

# Redis
REDIS_HOST=replace-with-railway-redis-host
REDIS_PORT=6379

# AI providers (optional but recommended)
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Email / notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Azure SSO (optional)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=common
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://api.your-domain.com/api/v1/auth/azure/callback
