{
  "name": "ai-it-ticketing-backend",
  "version": "1.0.0",
  "description": "Modular Fastify backend for AI IT ticketing system",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "migrate": "tsx src/utils/migrate.ts",
    "seed": "tsx src/utils/seed.ts",
    "seed-rules": "tsx src/utils/seed-rules.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.1033.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.13.0",
    "@fastify/swagger-ui": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.69.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "imap": "^0.8.19",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.6.5",
    "nodemailer": "^6.9.8",
    "pg": "^8.11.5",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/imap": "^0.8.43",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.20",
    "@types/pg": "^8.16.0",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vitest": "^4.0.18"
  }
