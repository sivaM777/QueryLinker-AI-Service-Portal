# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pit_portal

# AI Service
AI_CLASSIFIER_URL=http://localhost:8001/predict
# AI accuracy tuning (optional)
AI_TIER=free
LLM_PROVIDER=groq
AI_AUTO_TRAIN=true
AI_LOCAL_HF_ENABLED=false
AI_LOCAL_HF_ALWAYS=false
AI_LOCAL_HF_MODEL=typeform/distilbert-base-uncased-mnli
AI_LOCAL_HF_TRIGGER_THRESHOLD=0.55
AI_LOCAL_HF_MIN_SCORE=0.60
AI_LOCAL_HF_OVERRIDE_DELTA=0.12
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_EXTRACTION_MODEL=openai/gpt-oss-120b
GROQ_EXTRACTION_FALLBACK_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_NOTIFICATION_PROVIDER=auto
AI_NOTIFICATIONS_ENABLED=true
AI_NOTIFICATIONS_EMAIL_ENABLED=true
AI_NOTIFICATION_TIMEOUT_MS=1400
AI_CLOUD_PROVIDER=
AI_EMBED_PROVIDER=local
AI_CLOUD_CONFIDENCE_THRESHOLD=0.65
AI_CLOUD_TIMEOUT_SECONDS=10

# Auth (JWT)
JWT_SECRET=supersecretchangeinprod
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=14

# Azure AD SSO
AZURE_CLIENT_ID=
AZURE_TENANT_ID=common
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3000/api/v1/auth/azure/callback

# SMTP (Notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# SMS (Notifications)
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SMS_CUSTOM_API_URL=
SMS_CUSTOM_API_KEY=

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Public URLs / split deployment
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000/api/v1
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Cookie policy
# Use COOKIE_SAME_SITE=none and COOKIE_SECURE=true when the frontend and backend live on different domains.
COOKIE_SAME_SITE=strict
COOKIE_SECURE=
COOKIE_DOMAIN=
